# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=eso_auditing

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# ── Brevo Email ───────────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_FROM=noreply@yourdomain.com
BREVO_FROM_NAME=ESO Auditing System

# ── Email Queue ───────────────────────────────────────────────────────────────
# Delay between consecutive email sends (ms). Default: 200 ms ≈ 5/s ≈ 18,000/hr.
# Increase this value if you are on a lower Brevo plan with tighter rate limits.
EMAIL_QUEUE_DELAY_MS=200
# Maximum retry attempts for a failed send before the email is dropped.
EMAIL_QUEUE_MAX_RETRIES=3

# ── App ───────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# ── Optional ──────────────────────────────────────────────────────────────────
# TUNNEL_URL=https://your-tunnel.trycloudflare.com
# LAN_MODE=false
# BCRYPT_SALT_ROUNDS=10
